# ── DealRadar environment template (HANDOVER §9) ──────────────────────────────
# Copy to `.env` and fill in real values. NEVER commit `.env`.

# Runtime
NODE_ENV=production
PORT=3001
HOST_PORT=8080

# Postgres
POSTGRES_USER=dealradar
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=dealradar
DATABASE_URL=postgres://dealradar:change-me-strong-password@postgres:5432/dealradar

# Auth — JWT cookie signing secret (≥ 32 chars)
SESSION_SECRET=replace-with-a-random-string-at-least-32-chars

# Google OAuth (OIDC) — type "Web application"
# Authorised redirect URI: ${APP_BASE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
APP_BASE_URL=https://deal-radar.nikheelr.com

# Admin allowlist (comma-separated) — governs global settings only
ADMIN_EMAILS=rajmannikheel@gmail.com

# Optional — notifications
NOTIFICATION_WEBHOOK_URL=
RESEND_API_KEY=
ALERT_EMAIL_TO=

# Optional — Puppeteer (Tier B Takealot) chromium path inside Docker
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Optional — monetisation (post-MVP, public site only). Off by default.
ENABLE_ADS=false
ADS_CLIENT_ID=
KOFI_URL=
