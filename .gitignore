# ── Coverage & test artefacts ─────────────────────────────────────────────────
coverage/
.nyc_output/
playwright-report/
test-results/
blob-report/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── TypeScript cache ──────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Docker local overrides ────────────────────────────────────────────────────
docker-compose.override.yml

# ── Cloudflare Tunnel credentials (contain secrets) ───────────────────────────
