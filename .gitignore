# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ──────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/

# ── Environment / secrets — NEVER commit these ────────────────────────────────
.env
.env.local
.env.*.local
