{
  "name": "dealradar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Black Friday DealRadar — self-hosted SA price tracker with deal scoring",
  "license": "UNLICENSED",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "lint": "eslint . --max-warnings=0",
    "type-check": "npm run type-check --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:security": "node scripts/check-no-secrets-in-build.js",
    "build": "npm run build --workspaces --if-present",
    "qa": "npm run type-check && npm run lint && npm run test && npm run build",
    "sprint-verify": "bash scripts/sprint-verify.sh",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:logs": "docker compose logs -f",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
